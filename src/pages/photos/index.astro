---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { photoCollections } from "../../data/photoCollections";

const [birds, argusC4] = photoCollections;
---

<BaseLayout title="Photos · Nicholas Nazario">
  <section class="page-heading">
    <p class="eyebrow">Photography</p>
    <h1>Photos</h1>
    <p>A home for photographs I’ve taken. Usually birds, sometimes other stuff.</p>
  </section>

  <section class="collections" aria-labelledby="collections-heading">
    <div class="section-intro">
      <h2 id="collections-heading">Collections</h2>
    </div>

    <div class="collection-grid">
      <a class="collection-card birds" href={`/photos/${birds.slug}`} aria-labelledby="birds-heading">
        <div class="collection-art" aria-hidden="true">
          {birds.photos.length > 0 && (
            <div class="collection-collage">
              {birds.photos.slice(0, 3).map((photo) => <img src={photo} alt="" loading="lazy" />)}
            </div>
          )}
          <span class="sun"></span>
          <span class="bird bird-one">⌁</span>
          <span class="bird bird-two">⌁</span>
          <span class="branch"></span>
          <span class="grass grass-one"></span>
          <span class="grass grass-two"></span>
        </div>
        <div class="collection-copy">
          <p class="collection-number">{birds.number}</p>
          <h3 id="birds-heading">{birds.title}</h3>
          <p>{birds.description}</p>
          <span class="collection-status">{birds.photos.length} photographs <span aria-hidden="true">↗</span></span>
        </div>
      </a>

      <a class="collection-card argus-c4" href={`/photos/${argusC4.slug}`} aria-labelledby="argus-c4-heading">
        <div class="collection-art" aria-hidden="true">
          {argusC4.photos.length > 0 && (
            <div class="collection-collage">
              {argusC4.photos.slice(0, 3).map((photo) => <img src={photo} alt="" loading="lazy" />)}
            </div>
          )}
          <span class="skyline skyline-back"></span>
          <span class="skyline skyline-mid"></span>
          <span class="skyline skyline-front"></span>
          <span class="street-line street-line-one"></span>
          <span class="street-line street-line-two"></span>
          <span class="street-lamp"></span>
        </div>
        <div class="collection-copy">
          <p class="collection-number">{argusC4.number}</p>
          <h3 id="argus-c4-heading">{argusC4.title}</h3>
          <p>{argusC4.description}</p>
          <span class="collection-status">{argusC4.photos.length} photographs <span aria-hidden="true">↗</span></span>
        </div>
      </a>
    </div>
  </section>

  <section id="license" class="license">
    <h2>Photo license</h2>
    <p>
      Unless otherwise stated, photographs on this site are licensed under
      <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/">CC BY-NC-ND 4.0</a>.
      Noncommercial sharing is permitted with attribution. Modified versions
      and commercial use require separate written permission.
    </p>
  </section>
</BaseLayout>

<style>
  .page-heading { max-width: 52rem; padding-block: clamp(5rem, 12vw, 9rem) 3rem; }
  .eyebrow { color: #97603a; font-size: .75rem; font-weight: 700; letter-spacing: .16em; text-transform: uppercase; }
  h1 { margin: .6rem 0 .8rem; color: var(--forest); font-size: clamp(3.4rem, 9vw, 7rem); font-weight: 500; letter-spacing: -.07em; line-height: .85; }
  .page-heading p:last-child { color: var(--ink-soft); font-size: 1.2rem; }
  .collections { padding-block: 1.5rem; }
  .section-intro { display: flex; align-items: baseline; flex-wrap: wrap; gap: .8rem 1.4rem; margin-bottom: 2rem; }
  .section-kicker { margin: 0; color: var(--terracotta); font-size: .75rem; font-weight: 700; letter-spacing: .16em; text-transform: uppercase; }
  .section-intro h2 { margin: 0; color: var(--forest); font-size: 2.3rem; font-weight: 400; }
  .section-intro > p:last-child { flex-basis: 100%; margin: -.2rem 0 0; color: var(--ink-soft); font-size: 1.1rem; }
  .collection-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: clamp(1.2rem, 3vw, 2rem); }
  .collection-card { display: block; overflow: hidden; color: inherit; background: rgba(255, 255, 255, .34); border: 1px solid rgba(38, 63, 52, .14); border-radius: 2rem 4rem 2rem 4rem; box-shadow: 0 1.5rem 3rem rgba(38, 63, 52, .07); text-decoration: none; transition: transform .35s ease, box-shadow .35s ease; }
  .collection-card:hover { box-shadow: 0 1.8rem 3.5rem rgba(38, 63, 52, .14); transform: translateY(-5px); }
  .collection-art { position: relative; height: clamp(14rem, 27vw, 21rem); overflow: hidden; isolation: isolate; }
  .collection-collage { position: absolute; z-index: 4; inset: 0; display: grid; grid-template-columns: 1.2fr .8fr; grid-template-rows: 1fr 1fr; gap: .3rem; background: var(--paper); }
  .collection-collage img { width: 100%; height: 100%; min-width: 0; object-fit: cover; }
  .collection-collage img:first-child { grid-row: 1 / -1; }
  .birds .collection-art { background: linear-gradient(155deg, #b7d9cf 0%, #72a69b 55%, #2e6969 100%); }
  .birds .collection-art::after { position: absolute; inset: 0; z-index: -1; background: linear-gradient(115deg, transparent 50%, rgba(244, 238, 226, .2)); content: ""; }
  .sun { position: absolute; top: 16%; right: 15%; width: 4.5rem; height: 4.5rem; background: var(--honey); border-radius: 50%; box-shadow: 0 0 0 1rem rgba(242, 177, 76, .12), 0 0 3rem rgba(242, 177, 76, .38); }
  .bird { position: absolute; z-index: 2; color: var(--forest-deep); font-family: sans-serif; font-size: 5rem; font-weight: 700; line-height: 1; transform: rotate(-25deg); }
  .bird-one { top: 27%; left: 22%; }
  .bird-two { top: 40%; left: 41%; font-size: 3rem; transform: rotate(-18deg); }
  .branch { position: absolute; bottom: 23%; left: -5%; width: 76%; height: .45rem; background: #4a4732; border-radius: 100%; transform: rotate(-8deg); }
  .grass { position: absolute; bottom: -15%; width: 15rem; height: 10rem; border: solid #496e55; border-width: .35rem .35rem 0 0; border-radius: 100% 0 0 0; transform: rotate(28deg); }
  .grass-one { left: 8%; }
  .grass-two { right: -4%; transform: rotate(68deg); }
  .argus-c4 .collection-art { background: linear-gradient(160deg, #f4c982 0%, #d77d55 45%, #5d4953 100%); }
  .skyline { position: absolute; bottom: 22%; background: rgba(38, 63, 52, .46); }
  .skyline-back { left: 5%; width: 20%; height: 43%; }
  .skyline-mid { left: 27%; width: 27%; height: 62%; background: rgba(38, 63, 52, .7); }
  .skyline-front { right: 2%; width: 38%; height: 76%; background: var(--forest-deep); }
  .skyline::after { position: absolute; inset: 12% 15%; background: repeating-linear-gradient(to bottom, var(--honey) 0 .35rem, transparent .35rem 1.35rem); opacity: .55; content: ""; }
  .street-line { position: absolute; bottom: 0; left: 0; width: 100%; height: 25%; background: #394447; transform: skewY(-8deg); transform-origin: bottom left; }
  .street-line-one { z-index: 1; }
  .street-line-two { z-index: 2; bottom: -7%; left: 34%; width: 75%; background: #252f34; transform: skewY(16deg); }
  .street-lamp { position: absolute; z-index: 3; bottom: 29%; left: 19%; width: .35rem; height: 54%; background: var(--forest-deep); }
  .street-lamp::before { position: absolute; top: -.25rem; left: -.8rem; width: 1.9rem; height: .45rem; background: var(--forest-deep); border-radius: 1rem; content: ""; }
  .street-lamp::after { position: absolute; top: .1rem; left: -.35rem; width: 1rem; height: 1rem; background: var(--honey); border-radius: 50%; box-shadow: 0 0 1rem rgba(242, 177, 76, .8); content: ""; }
  .collection-copy { padding: 1.5rem clamp(1.3rem, 3vw, 2.25rem) 1.8rem; }
  .collection-number { margin: 0 0 .5rem; color: var(--terracotta); font-size: .7rem; font-weight: 700; letter-spacing: .15em; text-transform: uppercase; }
  .collection-copy h3 { margin: 0; color: var(--forest); font-size: 2.5rem; font-weight: 400; line-height: 1; }
  .collection-copy > p:not(.collection-number) { max-width: 24rem; margin: .85rem 0 1.3rem; color: var(--ink-soft); font-size: 1.05rem; }
  .collection-status { color: var(--sea); font-size: .9rem; font-weight: 700; }
  .collection-status span { display: inline-block; margin-left: .3rem; transition: transform .3s ease; }
  .collection-card:hover .collection-status span { transform: translate(3px, -3px); }
  .license { max-width: 42rem; margin-top: 5rem; padding-top: 2rem; border-top: 1px solid rgba(38, 63, 52, .18); color: var(--ink-soft); }
  .license h2 { color: var(--forest); font-family: "Chicle", "Trebuchet MS", sans-serif; font-size: 1.8rem; font-weight: 400; }
  .license a { color: var(--sea); }
  @media (max-width: 680px) { .collection-grid { grid-template-columns: 1fr; } }
</style>
