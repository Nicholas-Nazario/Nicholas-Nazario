---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Photos · Nicholas Nazario">
  <section class="page-heading">
    <p class="eyebrow">Photography</p>
    <h1>Photos</h1>
    <p>A home for photographs I’ve taken and collections I want to remember.</p>
  </section>

  <section class="empty-state" aria-labelledby="collections-heading">
    <h2 id="collections-heading">Collections are coming soon.</h2>
    <p>This page will become a photo album as collections are added.</p>
  </section>

  <section id="license" class="license">
    <h2>Photo license</h2>
    <p>
      Unless otherwise stated, photographs on this site are licensed under
      <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/">CC BY-NC-ND 4.0</a>.
      Noncommercial sharing is permitted with attribution. Modified versions
      and commercial use require separate written permission.
    </p>
  </section>
</BaseLayout>

<style>
  .page-heading { padding-block: 5rem 2rem; }
  .eyebrow { color: #8d4b2d; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; }
  h1 { margin: 0.5rem 0; font-size: clamp(3rem, 8vw, 6rem); line-height: 1; }
  .page-heading p:last-child { color: #706a61; font-size: 1.2rem; }
  .empty-state { padding: 2rem; border: 1px dashed #c9c0b4; }
  .empty-state h2 { margin-top: 0; }
  .license { max-width: 42rem; margin-top: 5rem; padding-top: 2rem; border-top: 1px solid #d8d0c4; color: #706a61; }
  .license h2 { color: #22201d; }
</style>
