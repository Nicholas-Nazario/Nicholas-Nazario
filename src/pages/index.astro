---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Nicholas Nazario">
  <section class="hero">
    <p class="eyebrow">Welcome</p>
    <h1>A place for things I’m making, thinking about, and seeing.</h1>
    <p class="intro">
      I’m a software engineer who likes birding, reading, cooking, and listening
      to music. This site is where I’ll share writing, photographs, and projects.
    </p>
    <div class="links">
      <a href="/blog">Read the blog →</a>
      <a href="/photos">Browse the photos →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero { max-width: 48rem; padding-block: clamp(5rem, 15vw, 10rem); }
  .eyebrow { color: #8d4b2d; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; }
  h1 { max-width: 12ch; margin: 1rem 0; font-size: clamp(3rem, 8vw, 6.5rem); line-height: 0.98; letter-spacing: -0.05em; }
  .intro { max-width: 38rem; color: #706a61; font-size: 1.25rem; }
  .links { display: flex; flex-wrap: wrap; gap: 1.5rem; margin-top: 2.5rem; font-weight: 700; }
</style>
