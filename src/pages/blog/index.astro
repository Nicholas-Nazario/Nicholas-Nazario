---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Blog · Nicholas Nazario">
  <section class="page-heading">
    <p class="eyebrow">Writing</p>
    <h1>Blog</h1>
    <p>Ramblings about mostly nothing. Every now and then, something.</p>
  </section>

  <p class="empty-state">The first post is on its way.</p>
</BaseLayout>

<style>
  .page-heading { padding-block: 5rem 2rem; }
  .eyebrow { color: #8d4b2d; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; }
  h1 { margin: 0.5rem 0; font-size: clamp(3rem, 8vw, 6rem); line-height: 1; }
  .page-heading p:last-child { color: #706a61; font-size: 1.2rem; }
  .empty-state { padding: 2rem; border: 1px dashed #c9c0b4; color: #706a61; }
</style>
